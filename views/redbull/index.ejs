<%- include('../partials/nav') %>
    
    <h1>Redbulls</h1>
    <br>
    <section class="cards">
      <%   allRedbulls.forEach((item)=>{%>
        <div class="redbulls">
          <a href="/redbulls/<%= item._id %>">
            
            <img src="<%= item.image.url %>" alt="" with="100" height="100">
            <br>
            <%= item.flavor  %>  
          </a>
        </div>
      <%   }) %>
    </section>

</body>
</html>