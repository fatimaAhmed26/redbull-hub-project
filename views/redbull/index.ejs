<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <ul>
    <h1>Index</h1>
   <%   allRedbulls.forEach((item)=>{%>
<li>
    <a href="/redbulls/<%= item._id %>">
      <%= item.flavor  %>  
    </a>
     
    <img src="<%= item.image.url %>" alt="" with="100" height="100">
    
</li>
  <%   }) %>
</ul>
</body>
</html>