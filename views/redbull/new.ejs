<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title> New Redbull</title>
</head>
<body>
    <h1>Crete a New Redbull</h1>
    <form action="/redbulls" method="post" enctype="multipart/form-data">
        <label for="flavor">flavor</label>
        <input type="text" name="flavor">
        <br>
        <label for="withSuger"></label>
        <label for="withSuger">With Suger?</label>
        <input type="checkbox" name="withSuger"> 
        <br>
        <label for="image">add image</label>
        <input type="file" name="image" id="image" accept="image/jpeg,image/png,image/webp" required>
        <br>
        <button type="submit">Add Redbull</button>
    </form>
</body>
</html>